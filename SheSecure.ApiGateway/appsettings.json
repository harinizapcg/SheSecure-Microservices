{
  "ReverseProxy": {
    "Routes": {
      "authRoute": {
        "ClusterId": "authCluster",
        "Match": {
          "Path": "/auth/{**catch-all}"
        }
      },

      "complaintRoute": {
        "ClusterId": "complaintCluster",
        "Match": {
          "Path": "/complaint/{**catch-all}"
        }
      },

      "safetyRoute": {
        "ClusterId": "safetyCluster",
        "Match": {
          "Path": "/safety/{**catch-all}"
        }
      },

      "notificationRoute": {
        "ClusterId": "notificationCluster",
        "Match": {
          "Path": "/notification/{**catch-all}"
        }
      },

      "dashboardRoute": {
        "ClusterId": "dashboardCluster",
        "Match": {
          "Path": "/dashboard/{**catch-all}"
        }
      }
    },

    "Clusters": {
      "authCluster": {
        "Destinations": {
          "destination1": {
            "Address": "https://localhost:5115/"
          }
        }
      },

      "complaintCluster": {
        "Destinations": {
          "destination1": {
            "Address": "https://localhost:5115/"
          }
        }
      },

      "safetyCluster": {
        "Destinations": {
          "destination1": {
            "Address": "https://localhost:5115/"
          }
        }
      },

      "notificationCluster": {
        "Destinations": {
          "destination1": {
            "Address": "https://localhost:5115/"
          }
        }
      },

      "dashboardCluster": {
        "Destinations": {
          "destination1": {
            "Address": "https://localhost:5115/"
          }
        }
      }
    }
  }
}