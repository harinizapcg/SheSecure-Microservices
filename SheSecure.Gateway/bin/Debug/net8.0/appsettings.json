{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "auth-route": {
        "ClusterId": "auth-cluster",
        "Match": { "Path": "/api/auth/{**catch-all}" }
      },
      "test-route": {
        "ClusterId": "auth-cluster",
        "Match": { "Path": "/api/test/{**catch-all}" }
      },
      "safety-route": {
        "ClusterId": "safety-cluster",
        "Match": { "Path": "/api/safereach/{**catch-all}" }
      },
      "emergency-route": {
        "ClusterId": "safety-cluster",
        "Match": { "Path": "/api/emergencyalert/{**catch-all}" }
      },
      "mood-route": {
        "ClusterId": "safety-cluster",
        "Match": { "Path": "/api/mood/{**catch-all}" }
      },
      "moodlog-route": {
        "ClusterId": "safety-cluster",
        "Match": { "Path": "/api/moodlog/{**catch-all}" }
      },
      "wellness-route": {
        "ClusterId": "safety-cluster",
        "Match": { "Path": "/api/wellnessrequest/{**catch-all}" }
      },
      "complaint-route": {
        "ClusterId": "complaint-cluster",
        "Match": { "Path": "/api/complaint/{**catch-all}" }
      },
      "complaintfiles-route": {
        "ClusterId": "complaint-cluster",
        "Match": { "Path": "/api/complaintfiles/{**catch-all}" }
      },
      "complaintcomments-route": {
        "ClusterId": "complaint-cluster",
        "Match": { "Path": "/api/complaintcomments/{**catch-all}" }
      },
      "complaintstatus-route": {
        "ClusterId": "complaint-cluster",
        "Match": { "Path": "/api/complaintstatushistory/{**catch-all}" }
      },
      "notification-route": {
        "ClusterId": "notification-cluster",
        "Match": { "Path": "/api/notification/{**catch-all}" }
      },
      "dashboard-route": {
        "ClusterId": "dashboard-cluster",
        "Match": { "Path": "/api/dashboard/{**catch-all}" }
      }
    },
    "Clusters": {
      "auth-cluster": {
        "Destinations": {
          "auth-dest": { "Address": "https://localhost:7271/" }
        }
      },
      "safety-cluster": {
        "Destinations": {
          "safety-dest": { "Address": "https://localhost:7044/" }
        }
      },
      "complaint-cluster": {
        "Destinations": {
          "complaint-dest": { "Address": "https://localhost:7032/" }
        }
      },
      "notification-cluster": {
        "Destinations": {
          "notification-dest": { "Address": "https://localhost:7179/" }
        }
      },
      "dashboard-cluster": {
        "Destinations": {
          "dashboard-dest": { "Address": "https://localhost:7077/" }
        }
      }
    }
  }
}